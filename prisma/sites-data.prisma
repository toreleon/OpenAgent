// ---------------------------------------------------------------------------
// ISOLATED datastore for the Sites "deployable mini-app" data plane (Phase 1).
//
// This is a SECOND, SEPARATE SQLite database + Prisma client, deliberately
// distinct from the primary app DB (prisma/schema.prisma → dev.db). Rationale
// (from the design's adversarial security review): SQLite is single-writer per
// file, so anonymous PUBLIC writes to a Site's data must NEVER share a writer
// with the app's authenticated traffic (login, chat) — else a write flood is a
// whole-app DoS. Keeping it a separate schema/client also means the mini-app
// feature touches NO shared file (no edit to the primary schema, no regen of the
// main client) — important while the primary schema is concurrently edited.
//
// The client is generated to a custom path (src/generated/sites-data-client,
// gitignored) so it never clobbers the default @prisma/client. Access goes
// exclusively through src/lib/sites/data-db.ts (WAL + busy_timeout + a
// tenant-scoped repository whose methods take siteId as a required first arg).
//
// There are NO cross-database foreign keys: every row references the primary
// Site by its plain string id (`siteId`); orphan cleanup is done in app code
// (the Site delete cascade), exactly like the app's other emulated cascades.
//
//   prisma generate --schema=prisma/sites-data.prisma
//   prisma db push  --schema=prisma/sites-data.prisma   (creates sites-data.db)
// ---------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/sites-data-client"
}

datasource db {
  provider = "sqlite"
  url      = env("SITES_DATA_URL")
}

/// Per-site backend config + master switch. Lives HERE (not as columns on the
/// primary Site) so the app DB stays untouched by the mini-app plane. Keyed by
/// the primary Site.id. A Site with no row here has the backend OFF.
model SiteBackendConfig {
  siteId         String   @id
  enabled        Boolean  @default(false) // master switch; data writes off until true
  dataQuotaBytes Int      @default(5242880) // 5 MiB/site
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// Per-site key/value store: counters, saved state, small config. `scope` is
/// "shared" now (one value per key, seen by every visitor); "visitor:<tok>"
/// arrives with per-visitor identity (Phase 2).
model SiteKV {
  id         String   @id @default(cuid())
  siteId     String
  collection String
  key        String
  value      String // JSON, size-capped by the handler
  scope      String   @default("shared")
  updatedAt  DateTime @updatedAt

  @@unique([siteId, collection, key, scope])
  @@index([siteId, collection])
}

/// Per-site append-only document collections: guestbook entries, poll votes,
/// form submissions. Read policy (owner-only vs public) is enforced by the
/// handler, not stored here.
model SiteDocument {
  id         String   @id @default(cuid())
  siteId     String
  collection String
  data       String // JSON
  createdAt  DateTime @default(now())

  @@index([siteId, collection, createdAt])
}

/// Denormalized per-site usage counters, updated in the SAME transaction as a
/// write so quota enforcement is atomic (no check-then-write race, no SUM() per
/// write).
model SiteUsage {
  siteId String @id
  bytes  Int    @default(0)
  rows   Int    @default(0)
}

/// An encrypted secret for a Site's fetch proxy (Phase 3). The VALUE is
/// AES-256-GCM ciphertext (nonce + AAD siteId||name); it is set by the OWNER and
/// never returned to any client or the model. See src/lib/sites/secrets.ts.
model SiteSecret {
  id         String   @id @default(cuid())
  siteId     String
  name       String
  ciphertext String
  nonce      String
  createdAt  DateTime @default(now())

  @@unique([siteId, name])
  @@index([siteId])
}

/// A proxied outbound endpoint for a Site (Phase 3). The MODEL proposes it
/// (name + method + urlTemplate) UNARMED; the OWNER arms it out-of-band by
/// approving the exact destination host + which secrets it may inject. It is
/// un-invocable until `armed`. Visitor {param} values fill query placeholders;
/// {{SECRET}} placeholders are filled server-side from SiteSecret.
model SiteEndpoint {
  id          String   @id @default(cuid())
  siteId      String
  name        String
  method      String   @default("GET")
  urlTemplate String
  approvedHost String? // OWNER-set; the resolved URL host must equal this
  secretRefs  String   @default("[]") // JSON string[] of secret names to inject
  armed       Boolean  @default(false)
  dailyBudget Int      @default(1000) // 0 = unlimited
  callsToday  Int      @default(0)
  dayStamp    String   @default("") // YYYY-MM-DD for the budget window
  createdAt   DateTime @default(now())

  @@unique([siteId, name])
  @@index([siteId])
}

/// A model-authored SERVER FUNCTION (Phase 4, custom-compute power tier). The
/// MODEL proposes {name, code} UNARMED via create_site; the OWNER arms it by
/// approving the EXACT source they reviewed (arm carries sha256 of the rendered
/// code; armFunction rejects if the stored code changed since — closes the arm
/// TOCTOU). It is un-runnable until armedHash === sha256(storedCode); any code
/// change re-disarms. Executed in a sandboxed QuickJS-WASM worker (see
/// src/lib/sites/fn/). This tier is default-OFF at every layer.
model SiteFunction {
  id        String   @id @default(cuid())
  siteId    String
  name      String
  code      String // JS source, <=64 KiB, <=20 rows/site (enforced at manifest time)
  armedHash String? // sha256 the owner approved; null = disarmed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, name])
  @@index([siteId])
}

/// Operator LIVE kill-switch for the whole function tier (no restart needed).
/// Single row (id="singleton"); cached ~5s in the pool.
model SiteFnRuntime {
  id             String   @id @default("singleton")
  globalDisabled Boolean  @default(false)
  updatedAt      DateTime @updatedAt
}

/// A named visitor ACCOUNT for a Site (Phase 2b): username + password login on
/// top of the anonymous visitor identity, so a visitor's data is portable across
/// devices. Accounts are per-Site (username unique within a siteId). Logged-in
/// private data is scoped `account:<id>` instead of `visitor:<token>`.
model SiteAccount {
  id           String   @id @default(cuid())
  siteId       String
  username     String
  passwordHash String
  createdAt    DateTime @default(now())

  @@unique([siteId, username])
  @@index([siteId])
}

/// Durable, bounded rate-limit buckets keyed by hash(siteId|ipBlock|window).
/// Lives in this DB (not in-process) so limits survive restarts and are shared
/// across workers; a sweeper hard-evicts expired rows so the table is bounded.
model SiteRateBucket {
  key       String   @id
  count     Int      @default(0)
  expiresAt DateTime

  @@index([expiresAt])
}
